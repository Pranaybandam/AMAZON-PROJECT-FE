resource "aws_security_group" "sgw" {
    name = "sgw"
    description = "Allow all inbound traffic"
    dynamic "ingress" {
    for_each= [8080,9000,22,443,80,3000] 
    content {
        from_port = ingress.value
        to_port = ingress.value
        protocol = "tcp"
        cidr_blocks = ["0.0.0.0/0"]
    } 
    }
    egress {
        from_port = 0
        to_port = 0
        protocol = "-1"
        cidr_blocks = ["0.0.0.0/0"]
    }   
  tags = {
    Name="sgw"
  }
}
